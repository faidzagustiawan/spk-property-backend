{
  "openapi": "3.0.0",
  "info": {
    "title": "SPK Property & ML API",
    "version": "1.1.0",
    "description": "Dokumentasi REST API (Full CRUD) untuk Sistem Pendukung Keputusan."
  },
  "servers": [ { "url": "http://localhost:5000/api/v1" } ],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "CasePayload": {
        "type": "object",
        "properties": {
          "case_name": { "type": "string", "example": "KPR Madiun" },
          "description": { "type": "string", "example": "Pemilihan rumah tipe 36" }
        }
      },
      "CriteriaPayload": {
        "type": "object",
        "properties": {
          "case_id": { "type": "integer", "example": 1 },
          "criteria_name": { "type": "string", "example": "Harga" },
          "criteria_type": { "type": "string", "example": "cost" },
          "weight": { "type": "number", "example": 0.5 }
        }
      }
    }
  },
  "security": [ { "bearerAuth": [] } ],
   "paths": {
    "/auth/register": {
      "post": {
        "tags": ["1. Authentication"],
        "summary": "Register user baru",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "admin" },
                  "password": { "type": "string", "example": "12345" },
                  "role": { "type": "string", "example": "user" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Registrasi berhasil" } }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["1. Authentication"],
        "summary": "Login untuk mendapatkan JWT Token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "example": "admin" },
                  "password": { "type": "string", "example": "12345" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Login berhasil, mengembalikan token" } }
      }
    },
    "/cases": {
      "post": {
        "tags": ["2. Decision Case"],
        "summary": "Membuat Decision Case baru",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CasePayload" } } } },
        "responses": { "201": { "description": "Success" } }
      },
      "get": {
        "tags": ["2. Decision Case"],
        "summary": "Mendapatkan semua Case user",
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/cases/{id}": {
      "get": {
        "tags": ["2. Decision Case"],
        "summary": "Mendapatkan detail Case berserta kriteria",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": { "200": { "description": "Success" } }
      },
      "put": {
        "tags": ["2. Decision Case"],
        "summary": "Mengubah nama/deskripsi Case",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CasePayload" } } } },
        "responses": { "200": { "description": "Success" } }
      },
      "delete": {
        "tags": ["2. Decision Case"],
        "summary": "Menghapus Case dan seluruh data di dalamnya secara permanen",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/criteria": {
      "post": {
        "tags": ["3. Criteria"],
        "summary": "Menambahkan kriteria",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CriteriaPayload" } } } },
        "responses": { "201": { "description": "Success" } }
      }
    },
    "/criteria/{case_id}": {
      "get": {
        "tags": ["3. Criteria"],
        "summary": "Mendapatkan list kriteria berdasarkan Case ID",
        "parameters": [ { "name": "case_id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/criteria/{id}": {
      "put": {
        "tags": ["3. Criteria"],
        "summary": "Mengubah kriteria (nama, tipe, bobot manual)",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CriteriaPayload" } } } },
        "responses": { "200": { "description": "Success" } }
      },
      "delete": {
        "tags": ["3. Criteria"],
        "summary": "Menghapus kriteria",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/alternatives/{id}": {
      "delete": {
        "tags": ["5. Alternatives"],
        "summary": "Menghapus alternatif",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } } ],
        "responses": { "200": { "description": "Success" } }
      }
    },
    "/spk/results/{case_id}": {
      "get": {
        "tags": ["6. SPK Ranking Algorithms"],
        "summary": "Melihat hasil kalkulasi tersimpan tanpa menghitung ulang",
        "parameters": [
          { "name": "case_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "method", "in": "query", "required": false, "schema": { "type": "string", "default": "SAW" } }
        ],
        "responses": { "200": { "description": "Success" } }
      }
    }
  }
}